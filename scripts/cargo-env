#!/usr/bin/env bash

detect_jobs() {
  if [[ -n "${JOBS:-}" ]]; then
    printf '%s\n' "$JOBS"
    return
  fi
  if [[ -n "${CARGO_BUILD_JOBS:-}" ]]; then
    printf '%s\n' "$CARGO_BUILD_JOBS"
    return
  fi
  if command -v nproc >/dev/null 2>&1; then
    nproc
    return
  fi
  if command -v getconf >/dev/null 2>&1; then
    getconf _NPROCESSORS_ONLN 2>/dev/null && return
  fi
  if command -v sysctl >/dev/null 2>&1; then
    sysctl -n hw.logicalcpu 2>/dev/null && return
    sysctl -n hw.ncpu 2>/dev/null && return
  fi
  printf '1\n'
}

append_bindgen_arg() {
  local arg="$1"
  if [[ " ${BINDGEN_EXTRA_CLANG_ARGS:-} " != *" ${arg} "* ]]; then
    export BINDGEN_EXTRA_CLANG_ARGS="${BINDGEN_EXTRA_CLANG_ARGS:+$BINDGEN_EXTRA_CLANG_ARGS }${arg}"
  fi
}

setup_ai_gateway_cargo_env() {
  local root jobs gcc_include candidate

  root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  cd "$root"

  jobs="$(detect_jobs)"
  if ! [[ "$jobs" =~ ^[0-9]+$ ]] || (( jobs < 1 )); then
    echo "cargo-env: invalid jobs value: $jobs" >&2
    return 2
  fi
  export CARGO_BUILD_JOBS="$jobs"

  if command -v gcc >/dev/null 2>&1; then
    gcc_include="$(gcc -print-file-name=include 2>/dev/null || true)"
    if [[ -n "$gcc_include" && -f "$gcc_include/stddef.h" ]]; then
      append_bindgen_arg "-isystem $gcc_include"
    fi
  fi

  if [[ -z "${LIBCLANG_PATH:-}" ]]; then
    for candidate in /usr/lib/llvm-*/lib /opt/homebrew/opt/llvm/lib /usr/local/opt/llvm/lib; do
      if compgen -G "$candidate/libclang*" >/dev/null 2>&1; then
        export LIBCLANG_PATH="$candidate"
        break
      fi
    done
  fi
}

setup_ai_gateway_cargo_env

if [[ "${BASH_SOURCE[0]}" == "$0" && $# -gt 0 ]]; then
  exec "$@"
fi
